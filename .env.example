# Main application settings
COMPOSE_PROJECT_NAME=falcon
DOMAIN=falcon.m2.loc
APP_PATH=application
APP_TIMEZONE=Europe/Kyiv

# MariaDB settings
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=falcon_m2
MARIADB_USER=root
MARIADB_PASSWORD=root
MARIADB_PORT=3306

# OpenSearch settings
OPENSEARCH_PORT=9200
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g
OPENSEARCH_DASHBOARDS_PORT=5601

# Redis settings
REDIS_PORT=6379

# RabbitMQ settings
RABBITMQ_DEFAULT_USER=magento
RABBITMQ_DEFAULT_PASS=magento
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# NGINX settings
NGINX_PORT=80
NGINX_SSL_PORT=443

# Mailpit (SMTP server) settings
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# phpMyAdmin settings
PHPMYADMIN_PORT=8080

# Magento admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# GitHub repository
# git@github.com:username/project.git - use if exist SSH
# username/project.git - standard login/password form
GITHUB_REPO=git@github.com:Yaradovhan/falcon.git
